NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_application
JWT_SECRET=replace-with-a-long-random-secret

# Optional. If omitted, checkout uses the built-in demo payment flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional. If omitted, order emails are printed to the server console.
RESEND_API_KEY=
ORDER_EMAIL_FROM=RaviCommerce <onboarding@resend.dev>

# Optional product image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
