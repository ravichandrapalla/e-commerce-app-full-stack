NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
# Production: https://boxinwheels.com,https://www.boxinwheels.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_application
JWT_SECRET=replace-with-a-long-random-secret

# Optional. If omitted, checkout uses the built-in demo payment flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional. If omitted, transactional emails log to the server console.
RESEND_API_KEY=
EMAIL_FROM=BoxInWheels <onboarding@resend.dev>
ORDER_EMAIL_FROM=BoxInWheels <onboarding@resend.dev>

# Required for seller/admin product images and profile avatars.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
